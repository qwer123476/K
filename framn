-- [안티치트 패시브 바이패스 - 상단에 배치]
task.spawn(function()
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)

    -- 1. 하위 속성 보호 감지 차단
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        -- 킥(Kick)이나 원격 이벤트 검증 차단
        if method == "Kick" or method == "kick" then
            return nil 
        end
        return oldNamecall(self, ...)
    end)
    setreadonly(mt, true)

    -- 2. 게임 하위 로그 및 에러 보고 감지 비활성화
    local LogService = game:GetService("LogService")
    LogService:ClearOutput()
    
    -- 3. 휴머노이드 속성 및 위치 관련 변조 감지 무력화 시도
    local player = game:GetService("Players").LocalPlayer
    local function disableAntiCheat(char)
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then
                -- 휴머노이드 속성 고정
                humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
                    humanoid.WalkSpeed = 16
                end)
            end
        end
    end
    
    player.CharacterAdded:Connect(disableAntiCheat)
    if player.Character then disableAntiCheat(player.Character) end
end)
